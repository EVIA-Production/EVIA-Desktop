# Required environment variables for signing/notarization local desktop builds.
# IMPORTANT: These belong to EVIA-Desktop only (NOT EVIA-Backend .env).
# Copy to .env.release (or export in shell) and NEVER commit real secrets.

# ============================================================================
# macOS Code Signing + Notarization (Apple Developer Program)
# ============================================================================
# Your Apple ID email used for the Developer Program
APPLE_ID=your@email.com

# App-specific password generated at https://appleid.apple.com/account/manage
# Security → App-Specific Passwords → Generate
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your 10-char Team ID from https://developer.apple.com/account → Membership
APPLE_TEAM_ID=XXXXXXXXXX

# Developer ID Application certificate (.p12):
# Either file path OR data URL
MAC_CSC_LINK=./certs/taylos-developer-id-application.p12
# MAC_CSC_LINK=data:application/x-pkcs12;base64,PASTE_BASE64_P12_HERE

# Password used when exporting the Developer ID Application .p12
MAC_CSC_KEY_PASSWORD=your-p12-export-password

# ============================================================================
# Windows Code Signing (Certum SimplySign)
# ============================================================================
# Path to exported .p12 certificate file, or base64-encoded content
# Export from SimplySign Desktop: Managing Certificates → right-click → Export
WIN_CSC_LINK=./certs/certum-taylos.p12

# Password used when exporting the .p12 file
WIN_CSC_KEY_PASSWORD=your-export-password
